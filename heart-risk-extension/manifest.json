{
  "manifest_version": 3,
  "name": "Heart Marker Risk Tracker",
  "version": "1.0.0",
  "description": "Track ApoB, Lipoprotein(a), and hs-CRP over time with a simple educational biomarker risk score.",
  "permissions": [
    "storage",
    "downloads"
  ],
  "action": {
    "default_title": "Heart Marker Risk Tracker",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}